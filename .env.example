APP_NAME=FCEI
PUBLIC_BASE_URL=https://yourdomain.com
ALLOWED_ORIGINS=https://yourdomain.com
JWT_SECRET=replace_with_64_random_characters
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=replace_with_long_admin_password
TOKEN_TTL_MINUTES=480
DATABASE_FILE=/app/data/finnish_paradigm.sqlite

# Stripe live commerce configuration
# Required in production; intentionally left blank in the package for security.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd
STRIPE_TAX_AUTOMATIC=0
STRIPE_ALLOW_PROMOTION_CODES=1
STRIPE_BILLING_PORTAL_RETURN_URL=https://yourdomain.com/dashboard.html

# Optional but recommended: real Stripe Product/Price IDs from your Stripe dashboard.
# If left blank, the app uses inline price_data for Checkout.
STRIPE_PRICE_TEACHER_STARTER=
STRIPE_PRICE_TEACHER_CERTIFICATE=
STRIPE_PRICE_EARLY_INTERVENTION=
STRIPE_PRICE_RETIRED_MENTOR=
STRIPE_PRICE_SCHOOL_LEADERSHIP=
STRIPE_PRICE_LEADERSHIP_DIPLOMA=
STRIPE_PRICE_TOOLKIT_BUNDLE=
STRIPE_PRICE_MEMBERSHIP_MONTHLY=
STRIPE_PRICE_SCHOOL_LICENSE=

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com

# Rate limiting (per IP)
RATE_LIMIT_WINDOW=300
RATE_LIMIT_MAX_AUTH=15
RATE_LIMIT_MAX_BOOKING=10

# Optional: set to 1 when live legal/payment/video checks are complete
COMMERCIAL_LAUNCH_APPROVED=0
